{
  "name": "alea",
  "description": "Filter-driven trader for Polymarket crypto up/down markets, fed by Pyth candles and live Polymarket books.",
  "type": "module",
  "private": true,
  "bin": {
    "alea": "src/bin/index.ts"
  },
  "module": "src/bin/index.ts",
  "scripts": {
    "alea": "bun run src/bin/index.ts",
    "typecheck": "bun x --bun tsc --noEmit",
    "test": "find src -name '*.test.ts' -print0 | xargs -0 bun test",
    "format": "if [ -x ./.tools/node/bin/node ]; then ./.tools/node/bin/node ./node_modules/prettier/bin/prettier.cjs --write .; else node ./node_modules/prettier/bin/prettier.cjs --write .; fi",
    "lint:fix": "if [ -x ./.tools/node/bin/node ]; then ./.tools/node/bin/node ./node_modules/eslint/bin/eslint.js --fix --cache .; else node ./node_modules/eslint/bin/eslint.js --fix --cache .; fi",
    "lint": "if [ -x ./.tools/node/bin/node ]; then ./.tools/node/bin/node ./node_modules/eslint/bin/eslint.js --cache .; else node ./node_modules/eslint/bin/eslint.js --cache .; fi"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "@types/pg-cursor": "^2.7.2",
    "eslint": "^9.39.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "dependencies": {
    "@polymarket/clob-client-v2": "^1.0.3",
    "ethers": "5",
    "kysely": "^0.28.15",
    "lightweight-charts": "^5.2.0",
    "pg": "^8.20.0",
    "pg-cursor": "^2.19.0",
    "picocolors": "^1.1.1",
    "playwright-core": "^1.60.0",
    "zod": "^4.3.6"
  }
}
